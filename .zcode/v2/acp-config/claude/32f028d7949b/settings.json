{
  "env": {
    "ANTHROPIC_BASE_URL": "https://api.kimi.com/coding/",
    "ANTHROPIC_AUTH_TOKEN": "sk-kimi-Jqc55uryKkCrq1kgEUxtuNEgfx7RPg7Xdrar2oG4j3Bqspbqrtsi01kus9xTn3Cs",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "API_TIMEOUT_MS": "3000000",
    "PROJECTS_DIR": "C:\\Users\\lk\\Documents\\Jeff1993\\Win_Claude_Work"
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "-",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"📋 MAPM Status:\\n$(bash ~/status/view.sh 2>/dev/null || echo \"view.sh not ready\")\"}'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "-",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"🔔 Remember to update status/win-desktop.yaml and run: git add -A && git commit -m \\\"agent:claude $(date +%Y%m%d-%H%M%S)\\\" && git push\"}'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import sys,json; d=json.load(sys.stdin); print(d.get('tool_input',{}).get('file_path','') or d.get('tool_response',{}).get('filePath',''))\" | bash \"$HOME/.claude/scripts/log-change.sh\" 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "autoresearch@autoresearch": true,
    "claude-hud@claude-hud": true,
    "warp@claude-code-warp": true,
    "skill-creator@claude-plugins-official": true,
    "everything-claude-code@everything-claude-code": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "autoresearch": {
      "source": {
        "source": "github",
        "repo": "uditgoenka/autoresearch"
      }
    },
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    },
    "everything-claude-code": {
      "source": {
        "source": "git",
        "url": "https://github.com/affaan-m/everything-claude-code.git"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true
}
